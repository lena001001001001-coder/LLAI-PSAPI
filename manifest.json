{
  "id": "llai.psapi",
  "name": "LLAI-PSAPI",
  "version": "1.2.2",
  "main": "index.html",
  "manifestVersion": 6,
  "host": {
    "app": "PS",
    "minVersion": "23.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "llai.psapi.panel",
      "label": {
        "default": "LLAI-PSAPI"
      },
      "minimumSize": {
        "width": 250,
        "height": 300
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 420
      },
      "preferredFloatingSize": {
        "width": 400,
        "height": 500
      },
      "icons": [
        {
          "width": 24,
          "height": 24,
          "path": "images/icon1.png",
          "scale": [1, 2],
          "theme": ["darkest","dark","medium","lightest","light","all"]
        }
      ]
    }
  ],
  "requiredPermissions": {
    "network": { "domains": "all" },
    "clipboard": "readAndWrite",
    "localFileSystem": "fullAccess",
    "launchProcess": {
      "schemes": ["http", "https"]
    },
    "allowCodeGenerationFromStrings": true
  },
  "icons": [
    {
      "width": 48,
      "height": 48,
      "path": "images/plugin-list-icon.png",
      "scale": [1, 2],
      "theme": ["darkest","dark","medium","lightest","light","all"],
      "species": ["pluginList"]
    }
  ]
}
